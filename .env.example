# ============================================================
# LiteLLM BYOK - Cấu hình API Keys
# Copy file này thành .env rồi điền key thật của bạn vào
# File .env KHÔNG được commit lên git (đã có trong .gitignore)
# ============================================================
#
# CÁCH THÊM NHIỀU KEY / NHIỀU MODEL:
#   Tăng số thứ tự PROFILE_N (1, 2, 3, ...)
#   - PROFILE_N_LABEL  : Tên hiển thị trong menu
#   - PROFILE_N_ENV_VAR: Tên biến môi trường cần set (xem config.yaml)
#   - PROFILE_N_KEY    : API key thật của bạn
#
# ============================================================

# --- Profile 1: DeepSeek chính chủ ---
# Lấy key tại: https://platform.deepseek.com/api_keys
PROFILE_1_LABEL=DeepSeek Official - deepseek-chat
PROFILE_1_ENV_VAR=DEEPSEEK_API_KEY
PROFILE_1_KEY=sk-your-deepseek-key-here

# --- Profile 2: DeepSeek qua DeepInfra ---
# Lấy key tại: https://deepinfra.com/dash/api_keys
PROFILE_2_LABEL=DeepInfra - DeepSeek V4 Pro
PROFILE_2_ENV_VAR=DEEPINFRA_API_KEY
PROFILE_2_KEY=your-deepinfra-key-here

# --- Profile 3: Google Gemini (AI Studio) ---
# Lấy key tại: https://aistudio.google.com/apikey
PROFILE_3_LABEL=Gemini 2.0 Flash (AI Studio)
PROFILE_3_ENV_VAR=GEMINI_API_KEY
PROFILE_3_KEY=your-gemini-key-here

# --- Profile 4: Ví dụ thêm key thứ 2 cho DeepSeek ---
# PROFILE_4_LABEL=DeepSeek Official - deepseek-reasoner
# PROFILE_4_ENV_VAR=DEEPSEEK_API_KEY
# PROFILE_4_KEY=sk-your-second-deepseek-key-here

# ============================================================
# LiteLLM Proxy Master Key (tùy chọn - dùng để xác thực proxy)
# Đặt bất kỳ chuỗi nào, ví dụ: sk-my-local-key
# ============================================================
LITELLM_MASTER_KEY=sk-change-me
